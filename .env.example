# scm-platform — local dev environment overrides
#
# Copy this file to .env to customize. .env is gitignored.
# Default values are baked into projects/scm-platform/docker-compose.yml.
# Hostname routing per ADR-MONO-001 Option C — no PORT_PREFIX needed.

# Hostname (must be present in /etc/hosts → 127.0.0.1)
PROJECT_HOSTNAME=scm.local

# GAP OIDC integration
# GAP exposes itself at http://iam.local/ via the shared Traefik stack
# (TASK-MONO-024 migrated GAP to hostname routing). Start GAP with
# `pnpm iam:up` and the shared Traefik stack with `pnpm traefik:up`.
# OIDC_ISSUER_URL: GAP's issuer base URL — no trailing /oauth2/ path.
#   Spring Security appends /.well-known/openid-configuration automatically.
OIDC_ISSUER_URL=http://iam.local
# JWT_JWKS_URI: explicit JWKS endpoint (avoids OpenID discovery round-trip in dev).
JWT_JWKS_URI=http://iam.local/oauth2/jwks

# OIDC client credentials (scm-platform-internal-services-client, registered in GAP V0013)
# OIDC_INTERNAL_CLIENT_ID is fixed — must match the client_id seeded in V0013.
# OIDC_INTERNAL_CLIENT_SECRET is the dev plaintext password whose BCrypt hash is
# stored in V0013. NEVER commit the production secret here — rotate via the GAP
# admin API or by overriding via env var in production environments.
# WARNING: "scm-dev" is a dev-only credential for local/portfolio use. Production
#          deployments must replace this with a strong, randomly generated secret
#          and rotate via admin API / vault.
OIDC_INTERNAL_CLIENT_ID=scm-platform-internal-services-client
OIDC_INTERNAL_CLIENT_SECRET=scm-dev

# Tenant gate — gateway-service rejects tokens whose tenant_id != "scm".
OIDC_REQUIRED_TENANT_ID=scm

# Spring profile (default | standalone | prod)
SPRING_PROFILES_ACTIVE=default

# Postgres — internal to scm-platform-net, no host port published.
# Per-service databases will be auto-created by infra/postgres/init/ once the
# first service skeleton (TASK-SCM-BE-001) lands the init script.
POSTGRES_USER=scm
POSTGRES_PASSWORD=scm
POSTGRES_DB=scm

# Redis — internal to scm-platform-net, no host port published.
# Leave blank for dev; set for staging/prod and ensure REDIS_PASSWORD reaches
# all services via their service environment.
REDIS_PASSWORD=

# Kafka — outbox relay target for transactional events. Internal-only.
KAFKA_BOOTSTRAP=kafka:9092

# CORS allowed origins (comma-separated). The gateway echoes these to
# preflight responses; production must use real frontend hostnames only.
# v1 = backend only — no frontend origins yet. Update when scm-platform-web
# lands in v2.
CORS_ALLOWED_ORIGINS=http://scm.local
